{
  "name": "@thepit/core",
  "version": "0.1.0",
  "description": "Core types, crypto, ranking, and payout logic for The Pit",
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "src"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "test": "node --import tsx --test src/**/*.test.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@noble/curves": "^1.9.0",
    "@noble/hashes": "^1.7.1"
  },
  "devDependencies": {
    "tsx": "^4.19.3"
  }
}